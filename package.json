{
  "name": "cdd-kit",
  "version": "0.1.1",
  "description": "Copilot-Driven Development — Framework de metodologia para desenvolvimento AI-augmented com Claude Code",
  "type": "module",
  "bin": {
    "cdd": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "copilot",
    "ai-development",
    "tdd",
    "methodology",
    "scaffolding",
    "cli"
  ],
  "author": "Danilo Rangel <danilorangelmg@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/danilorangelmg/cdd-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danilorangelmg/cdd-kit.git"
  },
  "bugs": {
    "url": "https://github.com/danilorangelmg/cdd-kit/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "handlebars": "^4.7.8",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
