#!/bin/bash
# PostToolUse Hook: Auto-run tests after code edit
# Detects module by file path and runs corresponding tests.
# Generated by cdd (Copilot-Driven Development)

set -euo pipefail

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')

if [ -z "$FILE_PATH" ]; then
  exit 0
fi

PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$(pwd)}"

# Detect module from file path
detect_module() {
  local fp="$1"
{{#each modules}}
  case "$fp" in
    *{{directory}}/*) echo "{{directory}}"; return ;;
  esac
{{/each}}
  echo ""
}

MODULE=$(detect_module "$FILE_PATH")

if [ -z "$MODULE" ]; then
  exit 0
fi

MODULE_DIR="$PROJECT_DIR/$MODULE"

# Only run tests for source code changes
case "$FILE_PATH" in
  *.py|*.ts|*.tsx|*.js|*.jsx|*.go|*.rs|*.java|*.kt|*.rb|*.swift) ;; # Source — run tests
  *) exit 0 ;; # Not source — skip
esac

# Run tests for the module
run_tests() {
  local mod_dir="$1"

  if [ -f "$mod_dir/Makefile" ]; then
    cd "$mod_dir" && make test 2>&1 | tail -20
  elif [ -f "$mod_dir/package.json" ]; then
    cd "$mod_dir" && npm test 2>&1 | tail -20
  elif [ -d "$mod_dir/tests" ]; then
    cd "$mod_dir" && python3 -m pytest tests/ -v --tb=short 2>&1 | tail -20
  fi
}

echo "--- Auto-Test [$MODULE] ---"
run_tests "$MODULE_DIR" || true
echo "--- End Auto-Test ---"

exit 0
