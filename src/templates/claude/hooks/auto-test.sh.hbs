#!/bin/bash
# PostToolUse Hook: Auto-run the RELATED test after code edit
# Runs only the specific test for the edited file (not the entire module).
# Full test suites run in final validation (post-dev-verify.sh / make test).
# Generated by cdd (Copilot-Driven Development)

set -euo pipefail

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')

if [ -z "$FILE_PATH" ]; then
  exit 0
fi

PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$(pwd)}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load shared test-finding functions
source "$SCRIPT_DIR/lib/find-test.sh"

# Detect module from file path
detect_module() {
  local fp="$1"
{{#each modules}}
  case "$fp" in
    *{{directory}}/*) echo "{{directory}}"; return ;;
  esac
{{/each}}
  echo ""
}

MODULE=$(detect_module "$FILE_PATH")

if [ -z "$MODULE" ]; then
  exit 0
fi

MODULE_DIR="$PROJECT_DIR/$MODULE"

# Only run tests for source code changes
case "$FILE_PATH" in
  *.py|*.ts|*.tsx|*.js|*.jsx|*.go) ;; # Source — run tests
  *) exit 0 ;; # Not source — skip
esac

# Check if the edited file IS a test
is_test_file() {
  case "$1" in
    */tests/*|*/test_*|*_test.*|*.test.*|*.spec.*|*/__tests__/*) return 0 ;;
    *) return 1 ;;
  esac
}

# Find the related test for the edited file
find_related_test() {
  local fp="$1"
  local mod="$2"
  local mod_dir="$3"

  # If the edited file is already a test, run it directly
  if is_test_file "$fp"; then
    echo "$fp"
    return
  fi

  # Extract relative path within src/
  local rel_path
  rel_path=$(echo "$fp" | sed -n "s|.*${mod}/src/||p")

  if [ -z "$rel_path" ]; then
    return
  fi

  # Dispatch to language-specific finder
  case "$fp" in
    *.py)
      find_python_test "$rel_path" "$mod_dir"
      ;;
    *.ts|*.tsx|*.js|*.jsx)
      find_ts_test "$rel_path" "$mod_dir"
      ;;
    *.go)
      find_go_test "$rel_path" "$mod_dir"
      ;;
  esac
}

TEST_FILE=$(find_related_test "$FILE_PATH" "$MODULE" "$MODULE_DIR")

if [ -z "$TEST_FILE" ]; then
{{#if (eq project.language "pt-BR")}}
  echo "[Auto-Test] Nenhum teste relacionado encontrado para $(basename "$FILE_PATH") — pulando"
{{else}}
  echo "[Auto-Test] No related test found for $(basename "$FILE_PATH") — skipping"
{{/if}}
  exit 0
fi

# Run only the related test (dispatch by file extension for robustness)
run_single_test() {
  local mod_dir="$1"
  local test_file="$2"

  case "$test_file" in
    *.py)
      cd "$mod_dir" && python3 -m pytest "$test_file" -v --tb=short --no-header 2>&1 | tail -20
      ;;
    *.test.ts*|*.spec.ts*|*.test.js*|*.spec.js*)
      cd "$mod_dir" && npx vitest run "$test_file" --reporter=verbose 2>&1 | tail -20
      ;;
    *_test.go)
      local pkg_dir
      pkg_dir=$(dirname "$test_file")
      cd "$mod_dir" && go test -v "./$pkg_dir/..." 2>&1 | tail -20
      ;;
    *)
      # Fallback: run module tests
      if [ -f "$mod_dir/Makefile" ]; then
        cd "$mod_dir" && make test 2>&1 | tail -20
      fi
      ;;
  esac
}

echo "[Auto-Test] Running $(basename "$TEST_FILE") in $MODULE..."
run_single_test "$MODULE_DIR" "$TEST_FILE" || true
echo "[Auto-Test] Done — $MODULE"

exit 0
