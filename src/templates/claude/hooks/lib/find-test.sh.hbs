# Python: find corresponding test file
# src/services/auth_service.py → tests/**/test_auth_service.py
find_python_test() {
  local rel="$1"
  local sub_dir="$2"
  local filename
  filename=$(basename "$rel" .py)

  # Direct match: test_{filename}.py
  local result
  result=$(find "$sub_dir/tests" -name "test_${filename}.py" 2>/dev/null | head -1)
  if [ -n "$result" ]; then
    echo "$result"
    return
  fi

  # Fallback: base name without suffix _service/_repository/_model/_schema/_route
  # Ex: auth_service.py → test_auth.py
  local base_name
  base_name=$(echo "$filename" | sed -E 's/_(service|repository|model|schema|route|handler|controller)$//')
  if [ "$base_name" != "$filename" ]; then
    result=$(find "$sub_dir/tests" -name "test_${base_name}.py" 2>/dev/null | head -1)
    if [ -n "$result" ]; then
      echo "$result"
      return
    fi
  fi

  # Fallback 2: any test that imports the module
  result=$(grep -Erl "from.*${filename}|import.*${filename}" "$sub_dir/tests" 2>/dev/null | head -1)
  if [ -n "$result" ]; then
    echo "$result"
    return
  fi
}

# TypeScript/JS: find corresponding test file
# src/components/Dashboard.tsx → tests/**/Dashboard.test.tsx
find_ts_test() {
  local rel="$1"
  local sub_dir="$2"
  local filename
  filename=$(basename "$rel" | sed -E 's/\.(ts|tsx|js|jsx)$//')

  # Search {filename}.test.{ext} or {filename}.spec.{ext} in tests/ and src/
  local result
  result=$(find "$sub_dir/tests" "$sub_dir/src" -name "${filename}.test.*" -o -name "${filename}.spec.*" 2>/dev/null | head -1)
  if [ -n "$result" ]; then
    echo "$result"
    return
  fi

  # Fallback: search in __tests__/ directories
  result=$(find "$sub_dir" -path "*/__tests__/${filename}.*" 2>/dev/null | head -1)
  if [ -n "$result" ]; then
    echo "$result"
    return
  fi
}

# Go: find corresponding test file
# pkg/services/auth.go → pkg/services/auth_test.go
find_go_test() {
  local rel="$1"
  local sub_dir="$2"
  local filename
  filename=$(basename "$rel" .go)
  local dir
  dir=$(dirname "$rel")

  # Go tests live in the same directory as the source
  local result
  result=$(find "$sub_dir/$dir" -name "${filename}_test.go" 2>/dev/null | head -1)
  if [ -n "$result" ]; then
    echo "$result"
    return
  fi

  # Fallback: search anywhere in the module
  result=$(find "$sub_dir" -name "${filename}_test.go" 2>/dev/null | head -1)
  if [ -n "$result" ]; then
    echo "$result"
    return
  fi
}
