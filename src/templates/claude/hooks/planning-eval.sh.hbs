#!/bin/bash
# UserPromptSubmit Hook: Planning Evaluation (Rule #3)
# Injects awareness of current planning phase/component before each response.
# Quick-exits if no active planning (no state file).
# Generated by cdd (Copilot-Driven Development)

STATE_DIR="${CLAUDE_PROJECT_DIR:-.}/.claude/project-memory/planning-state"
STATE_FILE=$(ls "$STATE_DIR"/*.json 2>/dev/null | head -1)

# Quick exit if no active planning
[ -z "$STATE_FILE" ] && exit 0

# Check if jq is available
if ! command -v jq &>/dev/null; then
{{#if (eq project.language "pt-BR")}}
  echo "[PLANNING] State file encontrado mas jq nao esta instalado. Instale com: brew install jq"
{{else}}
  echo "[PLANNING] State file found but jq is not installed. Install with: brew install jq"
{{/if}}
  exit 0
fi

# Parse state
FEATURE=$(jq -r '.feature // "unknown"' "$STATE_FILE")
CURRENT=$(jq -r '.current_component // "none"' "$STATE_FILE")
TOTAL=$(jq '[.components | length] | .[0] // 0' "$STATE_FILE")
COMPLETED=$(jq '[.components[] | select(.status=="completed")] | length' "$STATE_FILE")
PENDING_NAMES=$(jq -r '[.components[] | select(.status=="pending") | .name] | join(", ")' "$STATE_FILE")
CURRENT_STEPS=$(jq -r '.current_steps // {}' "$STATE_FILE")

# Build step status
UI_STATUS=$(echo "$CURRENT_STEPS" | jq -r '.ui // "PENDING"')
CONTRACT_STATUS=$(echo "$CURRENT_STEPS" | jq -r '.contract // "PENDING"')
ROUTE_STATUS=$(echo "$CURRENT_STEPS" | jq -r '.route // "PENDING"')
DATA_STATUS=$(echo "$CURRENT_STEPS" | jq -r '.data // "PENDING"')

{{#if (eq project.language "pt-BR")}}
cat << EOF
[PLANNING] Feature: $FEATURE ($COMPLETED/$TOTAL componentes concluidos)
Componente atual: $CURRENT
  Etapa 1 UI Design: $UI_STATUS
  Etapa 2 Contrato: $CONTRACT_STATUS
  Etapa 3 Rota BFF: $ROUTE_STATUS
  Etapa 4 Motor de Dados: $DATA_STATUS
Pendentes: $PENDING_NAMES
Ciclo: UI -> Contrato -> Rota BFF -> Motor de Dados -> VALIDAR -> proximo componente
PERGUNTE ao usuario sobre: UX, estados, dados, permissoes, edge cases, prioridade.
EOF
{{else}}
cat << EOF
[PLANNING] Feature: $FEATURE ($COMPLETED/$TOTAL components completed)
Current component: $CURRENT
  Step 1 UI Design: $UI_STATUS
  Step 2 Contract: $CONTRACT_STATUS
  Step 3 BFF Route: $ROUTE_STATUS
  Step 4 Data Engine: $DATA_STATUS
Pending: $PENDING_NAMES
Cycle: UI -> Contract -> BFF Route -> Data Engine -> VALIDATE -> next component
ASK the user about: UX, states, data, permissions, edge cases, priority.
EOF
{{/if}}

exit 0
