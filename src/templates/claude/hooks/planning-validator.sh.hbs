#!/bin/bash
# PostToolUse Hook: Planning Validator (Rule #3)
# Validates quality of planning docs after writing.
# Never blocks (exit 0), only provides feedback.
# Generated by cdd (Copilot-Driven Development)

set -uo pipefail

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null)

# Skip if no file_path
[ -z "$FILE_PATH" ] && exit 0

# Skip if not a planning doc
case "$FILE_PATH" in
  *{{paths.docsRoot}}/{{paths.rules}}/*) ;;
  *) exit 0 ;;
esac

# Skip if file doesn't exist (may have been deleted)
[ ! -f "$FILE_PATH" ] && exit 0

STATE_DIR="${CLAUDE_PROJECT_DIR:-.}/.claude/project-memory/planning-state"
STATE_FILE=$(ls "$STATE_DIR"/*.json 2>/dev/null | head -1)

# Skip if no active planning
[ -z "$STATE_FILE" ] && exit 0

ERRORS=""

{{#if (eq project.language "pt-BR")}}
# --- Validacao por tipo de documento ---

# Contratos de API
if [[ "$FILE_PATH" == *"contratos-api"* ]] || [[ "$FILE_PATH" == *"api-contracts"* ]]; then
  grep -qi "endpoint\|GET \|POST \|PUT \|DELETE \|PATCH " "$FILE_PATH" || ERRORS+="[FALHA] Nenhum endpoint definido\n"
  grep -qi "interface\|DTO\|type " "$FILE_PATH" || ERRORS+="[FALHA] Nenhum DTO/interface definido\n"
  grep -qi "erro\|error\|401\|403\|404\|422\|500" "$FILE_PATH" || ERRORS+="[FALHA] Cenarios de erro nao documentados\n"
{{#ifRule "api-response-contract"}}
  grep -qi "data\|envelope" "$FILE_PATH" || ERRORS+="[AVISO] Verificar se response segue Regra #4 (envelope data/error)\n"
{{/ifRule}}

# Regras de negocio — Frontend
elif [[ "$FILE_PATH" == *"{{paths.businessRules}}"* ]] && [[ "$FILE_PATH" == *"/front"* || "$FILE_PATH" == *"/mobile"* ]]; then
  grep -qi "componente\|component" "$FILE_PATH" || ERRORS+="[FALHA] Nenhum componente listado\n"
  grep -qi "loading\|empty\|error\|estado\|skeleton" "$FILE_PATH" || ERRORS+="[FALHA] Estados visuais (loading/empty/error) nao definidos\n"
  grep -qi "props\|dados\|consome\|recebe" "$FILE_PATH" || ERRORS+="[AVISO] Props/dados consumidos nao documentados\n"

# Regras de negocio — Backend
elif [[ "$FILE_PATH" == *"{{paths.businessRules}}"* ]] && [[ "$FILE_PATH" == *"/bff"* || "$FILE_PATH" == *"/api"* || "$FILE_PATH" == *"/backend"* ]]; then
  grep -qi "regra\|validac\|transform\|calculo\|rule\|validation" "$FILE_PATH" || ERRORS+="[FALHA] Nenhuma regra de negocio definida\n"
  grep -qi "fonte\|tabela\|banco\|API\|query\|source\|table\|database" "$FILE_PATH" || ERRORS+="[FALHA] Fonte de dados nao definida\n"

# Regras de negocio — Agent
elif [[ "$FILE_PATH" == *"{{paths.businessRules}}"* ]] && [[ "$FILE_PATH" == *"/agent"* ]]; then
  grep -qi "regra\|pipeline\|scheduler\|trigger\|rule" "$FILE_PATH" || ERRORS+="[FALHA] Nenhuma regra de motor/pipeline definida\n"

# Regras de negocio — DB
elif [[ "$FILE_PATH" == *"{{paths.businessRules}}"* ]] && [[ "$FILE_PATH" == *"/db"* || "$FILE_PATH" == *"/database"* ]]; then
  grep -qi "tabela\|campo\|migration\|schema\|coluna\|table\|column" "$FILE_PATH" || ERRORS+="[FALHA] Nenhuma definicao de schema/tabela\n"
fi

# --- Output ---
if [ -n "$ERRORS" ]; then
  echo "--- Planning Validator ---"
  echo -e "$ERRORS"
  echo "Corrija antes de avancar ao proximo componente."
  echo "--- Fim Validator ---"
else
  if [[ "$FILE_PATH" == *"{{paths.businessRules}}"* ]] || [[ "$FILE_PATH" == *"contratos-api"* ]]; then
    echo "[Planning Validator] OK — $(basename "$FILE_PATH") valido."
  fi
fi
{{else}}
# --- Validation by document type ---

# API Contracts
if [[ "$FILE_PATH" == *"api-contracts"* ]] || [[ "$FILE_PATH" == *"contratos-api"* ]]; then
  grep -qi "endpoint\|GET \|POST \|PUT \|DELETE \|PATCH " "$FILE_PATH" || ERRORS+="[FAIL] No endpoints defined\n"
  grep -qi "interface\|DTO\|type " "$FILE_PATH" || ERRORS+="[FAIL] No DTO/interface defined\n"
  grep -qi "error\|401\|403\|404\|422\|500" "$FILE_PATH" || ERRORS+="[FAIL] Error scenarios not documented\n"
{{#ifRule "api-response-contract"}}
  grep -qi "data\|envelope" "$FILE_PATH" || ERRORS+="[WARN] Verify response follows Rule #4 (data/error envelope)\n"
{{/ifRule}}

# Business rules — Frontend
elif [[ "$FILE_PATH" == *"{{paths.businessRules}}"* ]] && [[ "$FILE_PATH" == *"/front"* || "$FILE_PATH" == *"/mobile"* ]]; then
  grep -qi "component" "$FILE_PATH" || ERRORS+="[FAIL] No components listed\n"
  grep -qi "loading\|empty\|error\|state\|skeleton" "$FILE_PATH" || ERRORS+="[FAIL] Visual states (loading/empty/error) not defined\n"
  grep -qi "props\|data\|consumes\|receives" "$FILE_PATH" || ERRORS+="[WARN] Props/data consumed not documented\n"

# Business rules — Backend
elif [[ "$FILE_PATH" == *"{{paths.businessRules}}"* ]] && [[ "$FILE_PATH" == *"/bff"* || "$FILE_PATH" == *"/api"* || "$FILE_PATH" == *"/backend"* ]]; then
  grep -qi "rule\|validation\|transform\|calculation" "$FILE_PATH" || ERRORS+="[FAIL] No business rules defined\n"
  grep -qi "source\|table\|database\|API\|query" "$FILE_PATH" || ERRORS+="[FAIL] Data source not defined\n"

# Business rules — Agent
elif [[ "$FILE_PATH" == *"{{paths.businessRules}}"* ]] && [[ "$FILE_PATH" == *"/agent"* ]]; then
  grep -qi "rule\|pipeline\|scheduler\|trigger" "$FILE_PATH" || ERRORS+="[FAIL] No engine/pipeline rules defined\n"

# Business rules — DB
elif [[ "$FILE_PATH" == *"{{paths.businessRules}}"* ]] && [[ "$FILE_PATH" == *"/db"* || "$FILE_PATH" == *"/database"* ]]; then
  grep -qi "table\|column\|migration\|schema" "$FILE_PATH" || ERRORS+="[FAIL] No schema/table definition found\n"
fi

# --- Output ---
if [ -n "$ERRORS" ]; then
  echo "--- Planning Validator ---"
  echo -e "$ERRORS"
  echo "Fix issues before advancing to the next component."
  echo "--- End Validator ---"
else
  if [[ "$FILE_PATH" == *"{{paths.businessRules}}"* ]] || [[ "$FILE_PATH" == *"api-contracts"* ]]; then
    echo "[Planning Validator] OK — $(basename "$FILE_PATH") is valid."
  fi
fi
{{/if}}

# Never blocks — feedback only
exit 0
