#!/usr/bin/env bash
# Stop Hook: Post-Development Verification Pipeline
# Detects changed modules and runs verification on each.
# Registered in .claude/settings.json as Stop hook.
# Generated by cdd (Copilot-Driven Development)

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
VERIFY_SCRIPT="$SCRIPT_DIR/../verify/run.sh"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Valid modules
VALID_MODULES="{{#each modules}}{{directory}}{{#unless @last}} {{/unless}}{{/each}}"

# Detect changed modules (staged + unstaged + untracked)
detect_changed_modules() {
  local changed_dirs=""

  # Modified files (staged + unstaged)
  changed_dirs=$(cd "$ROOT_DIR" && git diff --name-only HEAD 2>/dev/null | cut -d'/' -f1 | sort -u)

  # Untracked files
  local untracked
  untracked=$(cd "$ROOT_DIR" && git ls-files --others --exclude-standard 2>/dev/null | cut -d'/' -f1 | sort -u)
  changed_dirs=$(echo -e "$changed_dirs\n$untracked" | sort -u | grep -v '^$')

  # Staged changes
  local staged_changes
  staged_changes=$(cd "$ROOT_DIR" && git diff --name-only --cached 2>/dev/null | cut -d'/' -f1 | sort -u)
  changed_dirs=$(echo -e "$changed_dirs\n$staged_changes" | sort -u | grep -v '^$')

  # Filter only valid modules
  local result=""
  for dir in $changed_dirs; do
    if echo "$VALID_MODULES" | grep -qw "$dir"; then
      result="$result $dir"
    fi
  done

  echo "$result" | xargs
}

# --- Main ---
CHANGED=$(detect_changed_modules)

if [[ -z "$CHANGED" ]]; then
{{#if (eq project.language "pt-BR")}}
  echo -e "${GREEN}Nenhum modulo alterado. Verificacao nao necessaria.${NC}"
{{else}}
  echo -e "${GREEN}No modules changed. Verification not needed.${NC}"
{{/if}}
  exit 0
fi

echo ""
echo -e "${BOLD}${CYAN}================================================${NC}"
{{#if (eq project.language "pt-BR")}}
echo -e "${BOLD}${CYAN}  POST-DEV VERIFY — Modulos alterados${NC}"
{{else}}
echo -e "${BOLD}${CYAN}  POST-DEV VERIFY — Changed modules${NC}"
{{/if}}
echo -e "${BOLD}${CYAN}================================================${NC}"
{{#if (eq project.language "pt-BR")}}
echo -e "  Detectados: ${YELLOW}$CHANGED${NC}"
{{else}}
echo -e "  Detected: ${YELLOW}$CHANGED${NC}"
{{/if}}
echo ""

TOTAL_FAILED=0
FAILED_MODULES=()

for module in $CHANGED; do
  if [[ ! -x "$VERIFY_SCRIPT" ]]; then
{{#if (eq project.language "pt-BR")}}
    echo -e "${RED}Script de verificacao nao encontrado: $VERIFY_SCRIPT${NC}"
{{else}}
    echo -e "${RED}Verify script not found: $VERIFY_SCRIPT${NC}"
{{/if}}
    exit 1
  fi

  "$VERIFY_SCRIPT" "$module" || {
    ((TOTAL_FAILED++)) || true
    FAILED_MODULES+=("$module")
  }
done

echo ""
echo -e "${BOLD}${CYAN}================================================${NC}"
{{#if (eq project.language "pt-BR")}}
echo -e "${BOLD}${CYAN}  RESULTADO CONSOLIDADO${NC}"
{{else}}
echo -e "${BOLD}${CYAN}  CONSOLIDATED RESULT${NC}"
{{/if}}
echo -e "${BOLD}${CYAN}================================================${NC}"

if [[ $TOTAL_FAILED -eq 0 ]]; then
{{#if (eq project.language "pt-BR")}}
  echo -e "  ${GREEN}Todos os modulos passaram na verificacao!${NC}"
{{else}}
  echo -e "  ${GREEN}All modules passed verification!${NC}"
{{/if}}
else
{{#if (eq project.language "pt-BR")}}
  echo -e "  ${RED}$TOTAL_FAILED modulo(s) com falhas: ${FAILED_MODULES[*]}${NC}"
  echo -e "  ${YELLOW}Corrija os problemas e rode: make verify${NC}"
{{else}}
  echo -e "  ${RED}$TOTAL_FAILED module(s) with failures: ${FAILED_MODULES[*]}${NC}"
  echo -e "  ${YELLOW}Fix the issues and run: make verify${NC}"
{{/if}}
fi

echo ""
exit $TOTAL_FAILED
