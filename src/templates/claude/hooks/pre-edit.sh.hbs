#!/bin/bash
# PreToolUse Hook Consolidado: TDD Guard + Planning Gate
# Combina tdd-guard.sh e planning-gate.sh em um unico processo
# para reduzir overhead de spawn (2 processos → 1).
# Generated by cdd (Copilot-Driven Development)
#
# Exit 0 = allow edit
# Exit 2 = block edit (stderr becomes feedback to agent)

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$(pwd)}"

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')

if [ -z "$FILE_PATH" ]; then
  exit 0
fi

{{#ifRule "feature-planning-gate"}}
# ============================================================
# PART 1: Planning Gate (fast — skip if not a rules doc)
# ============================================================
case "$FILE_PATH" in
  *{{paths.docsRoot}}/{{paths.businessRules}}/*)
    STATE_DIR="$PROJECT_DIR/.claude/project-memory/planning-state"
    STATE_FILE=$(ls "$STATE_DIR"/*.json 2>/dev/null | head -1)

    if [ -n "$STATE_FILE" ] && command -v jq &>/dev/null; then
      PENDING=$(jq '[.components[] | select(.status=="pending")] | length' "$STATE_FILE" 2>/dev/null)

{{#if (eq project.language "pt-BR")}}
      if [[ "$FILE_PATH" == *"{{paths.devPlans}}"* ]] && [ "${PENDING:-0}" -gt 0 ]; then
        echo "Planning Gate: BLOQUEADO. $PENDING componente(s) ainda pendente(s)." >&2
        echo "Complete o ciclo (UI -> Contrato -> Rota -> Dados) de todos os componentes antes de gerar {{paths.devPlans}}." >&2
        exit 2
      fi

      if [[ "$FILE_PATH" == *"{{paths.testPlans}}"* ]] && [ "${PENDING:-0}" -gt 0 ]; then
        echo "Planning Gate: BLOQUEADO. $PENDING componente(s) ainda pendente(s)." >&2
        echo "Complete o ciclo de todos os componentes antes de gerar {{paths.testPlans}}." >&2
        exit 2
      fi

      echo "[Planning Gate] OK — sem bloqueio para $(basename "$FILE_PATH")"
{{else}}
      if [[ "$FILE_PATH" == *"{{paths.devPlans}}"* ]] && [ "${PENDING:-0}" -gt 0 ]; then
        echo "Planning Gate: BLOCKED. $PENDING component(s) still pending." >&2
        echo "Complete the cycle (UI -> Contract -> Route -> Data) for all components before generating {{paths.devPlans}}." >&2
        exit 2
      fi

      if [[ "$FILE_PATH" == *"{{paths.testPlans}}"* ]] && [ "${PENDING:-0}" -gt 0 ]; then
        echo "Planning Gate: BLOCKED. $PENDING component(s) still pending." >&2
        echo "Complete the cycle for all components before generating {{paths.testPlans}}." >&2
        exit 2
      fi

      echo "[Planning Gate] OK — no block for $(basename "$FILE_PATH")"
{{/if}}
    fi
    # Planning gate does not block other doc types — fall through to TDD guard
    ;;
esac
{{/ifRule}}

{{#ifRule "tdd-enforcement"}}
# ============================================================
# PART 2: TDD Guard (source code files in modules only)
# ============================================================

# Skip non-source files
case "$FILE_PATH" in
  *.py|*.ts|*.tsx|*.js|*.jsx) ;; # Source code — check
  *) exit 0 ;; # Config, docs, etc — allow
esac

# Detect module from file path
detect_module() {
  local fp="$1"
{{#each modules}}
  case "$fp" in
    *{{directory}}/*) echo "{{directory}}"; return ;;
  esac
{{/each}}
  echo ""
}

MODULE=$(detect_module "$FILE_PATH")

# If not in any module, allow
if [ -z "$MODULE" ]; then
  exit 0
fi

# If the file IS a test, ALWAYS allow (Red phase)
case "$FILE_PATH" in
  */tests/*|*/test_*|*_test.*|*.test.*|*.spec.*|*/__tests__/*)
    exit 0
    ;;
esac

# If the file is NOT in src/, allow (configs, docs, etc)
# Boilerplate files are always allowed
case "$FILE_PATH" in
  */__init__.py|*/main.py|*/conftest.py|*/index.ts|*/index.js)
    exit 0
    ;; # Boilerplate — allow
  */src/*)
    ;; # Implementation — check for test
  *)
    exit 0
    ;; # Not implementation — allow
esac

MODULE_DIR="$PROJECT_DIR/$MODULE"

# Extract relative path within src/
REL_PATH=$(echo "$FILE_PATH" | sed -n "s|.*${MODULE}/src/||p")

if [ -z "$REL_PATH" ]; then
  exit 0
fi

# Load shared test-finding functions
source "$SCRIPT_DIR/lib/find-test.sh"

TEST_FILE=""

case "$FILE_PATH" in
  *.py)
    TEST_FILE=$(find_python_test "$REL_PATH" "$MODULE_DIR")
    ;;
  *.ts|*.tsx|*.js|*.jsx)
    TEST_FILE=$(find_ts_test "$REL_PATH" "$MODULE_DIR")
    ;;
esac

if [ -z "$TEST_FILE" ]; then
  FILENAME=$(basename "$REL_PATH" | sed -E 's/\.(py|ts|tsx|js|jsx)$//')

  case "$FILE_PATH" in
    *.py)
      SUGGESTED="$MODULE/tests/unit/$(dirname "$REL_PATH")/test_${FILENAME}.py"
      ;;
    *.ts|*.tsx)
      SUGGESTED="$MODULE/tests/$(dirname "$REL_PATH")/${FILENAME}.test.tsx"
      ;;
    *)
      SUGGESTED="$MODULE/tests/test_${FILENAME}"
      ;;
  esac

{{#if (eq project.language "pt-BR")}}
  echo "TDD Guard: Bloqueado. Nao existe teste para '${MODULE}/src/${REL_PATH}'." >&2
  echo "Crie o teste primeiro (Red phase): ${SUGGESTED}" >&2
  echo "Lembre: escreva o teste ANTES de implementar. O teste deve FALHAR inicialmente." >&2
{{else}}
  echo "TDD Guard: Blocked. No test found for '${MODULE}/src/${REL_PATH}'." >&2
  echo "Write the test first (Red phase): ${SUGGESTED}" >&2
  echo "Remember: write the test BEFORE implementing. The test should FAIL initially." >&2
{{/if}}
  exit 2
fi

{{#if (eq project.language "pt-BR")}}
echo "[TDD Guard] OK — teste encontrado: $(basename "$TEST_FILE")"
{{else}}
echo "[TDD Guard] OK — test found: $(basename "$TEST_FILE")"
{{/if}}
{{/ifRule}}
exit 0
