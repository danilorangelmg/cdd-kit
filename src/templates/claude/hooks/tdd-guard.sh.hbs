#!/bin/bash
# PreToolUse Hook: TDD Guard
# Blocks editing implementation files (src/) if no corresponding test exists.
# Generated by cdd (Copilot-Driven Development)
#
# Exit 0 = allow edit
# Exit 2 = block edit (stderr becomes feedback to agent)

set -uo pipefail

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')

if [ -z "$FILE_PATH" ]; then
  exit 0
fi

PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$(pwd)}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load shared test-finding functions
source "$SCRIPT_DIR/lib/find-test.sh"

# Only check source code files
case "$FILE_PATH" in
  *.py|*.ts|*.tsx|*.js|*.jsx|*.go|*.rs|*.java|*.kt|*.rb|*.swift) ;; # Source — check
  *) exit 0 ;; # Config, docs, etc — allow
esac

# Read modules from cdd.json
if [ ! -f "$PROJECT_DIR/cdd.json" ]; then
  exit 0
fi

# Detect module from file path
detect_module() {
  local fp="$1"
{{#each modules}}
  case "$fp" in
    *{{directory}}/*) echo "{{directory}}"; return ;;
  esac
{{/each}}
  echo ""
}

MODULE=$(detect_module "$FILE_PATH")

# If not in any module, allow
if [ -z "$MODULE" ]; then
  exit 0
fi

# If the file IS a test, ALWAYS allow (Red phase)
case "$FILE_PATH" in
  */tests/*|*/test_*|*_test.*|*.test.*|*.spec.*|*/__tests__/*)
    exit 0
    ;;
esac

# If the file is NOT in src/, allow (configs, docs, etc)
case "$FILE_PATH" in
  */__init__.py|*/main.py|*/conftest.py|*/index.ts|*/index.js)
    exit 0
    ;; # Boilerplate — allow
  */src/*)
    ;; # Implementation — check for test
  *)
    exit 0
    ;; # Not implementation — allow
esac

MODULE_DIR="$PROJECT_DIR/$MODULE"

# Extract relative path within src/
REL_PATH=$(echo "$FILE_PATH" | sed -n "s|.*${MODULE}/src/||p")

if [ -z "$REL_PATH" ]; then
  exit 0
fi

# Search for corresponding test file using shared library
FILENAME=$(basename "$REL_PATH" | sed -E 's/\.(py|ts|tsx|js|jsx|go|rs|java|kt|rb|swift)$//')
TEST_FILE=""

case "$FILE_PATH" in
  *.py)
    TEST_FILE=$(find_python_test "$REL_PATH" "$MODULE_DIR")
    ;;
  *.ts|*.tsx|*.js|*.jsx)
    TEST_FILE=$(find_ts_test "$REL_PATH" "$MODULE_DIR")
    ;;
  *.go)
    TEST_FILE=$(find_go_test "$REL_PATH" "$MODULE_DIR")
    ;;
esac

if [ -z "$TEST_FILE" ]; then
{{#if (eq project.language "pt-BR")}}
  echo "TDD Guard: Bloqueado. Nenhum teste encontrado para '${MODULE}/src/${REL_PATH}'." >&2
  echo "Escreva o teste primeiro (fase Red): ${MODULE}/tests/test_${FILENAME}.*" >&2
  echo "Lembre-se: escreva o teste ANTES de implementar. O teste deve FALHAR inicialmente." >&2
{{else}}
  echo "TDD Guard: Blocked. No test found for '${MODULE}/src/${REL_PATH}'." >&2
  echo "Write the test first (Red phase): ${MODULE}/tests/test_${FILENAME}.*" >&2
  echo "Remember: write the test BEFORE implementing. The test should FAIL initially." >&2
{{/if}}
  exit 2
fi

# Test exists — allow edit
exit 0
