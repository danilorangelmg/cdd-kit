{
  "hooks": {
{{#if (or (lookup methodology.rules "tdd-enforcement") (lookup methodology.rules "feature-planning-gate"))}}
    "PreToolUse": [
{{#ifRule "tdd-enforcement"}}
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/tdd-guard.sh"
          }
        ]
      }{{#ifRule "feature-planning-gate"}},{{/ifRule}}
{{/ifRule}}
{{#ifRule "feature-planning-gate"}}
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/planning-gate.sh"
          }
        ]
      }
{{/ifRule}}
    ],
    "PostToolUse": [
{{#ifRule "tdd-enforcement"}}
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-test.sh"
          }
        ]
      }{{#ifRule "feature-planning-gate"}},{{/ifRule}}
{{/ifRule}}
{{#ifRule "feature-planning-gate"}}
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/planning-validator.sh"
          }
        ]
      }
{{/ifRule}}
    ],
    "UserPromptSubmit": [
{{#ifRule "tdd-enforcement"}}
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/tdd-eval.sh"
          }
        ]
      }{{#ifRule "feature-planning-gate"}},{{/ifRule}}
{{/ifRule}}
{{#ifRule "feature-planning-gate"}}
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/planning-eval.sh"
          }
        ]
      }
{{/ifRule}}
    ],
{{/if}}
    "Stop": [
{{#ifRule "tdd-enforcement"}}
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check if the agent just completed code changes in any module ({{#each modules}}{{name}}{{#unless @last}}, {{/unless}}{{/each}}). If yes, verify: 1) Were tests written BEFORE implementation? 2) Do all tests pass? If any check fails, respond with {\"ok\": false, \"reason\": \"description\"}. If all pass or no code changed, respond with {\"ok\": true}."
          }
        ]
      },
{{/ifRule}}
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-dev-verify.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": [
{{#ifRule "e2e-test-protection"}}
{{#modulesOfRole "e2e"}}
      "Edit(/{{directory}}/features/**)",
      "Write(/{{directory}}/features/**)",
      "Edit(/{{directory}}/step-definitions/**)",
      "Write(/{{directory}}/step-definitions/**)",
      "Edit(/{{directory}}/support/**)",
      "Write(/{{directory}}/support/**)"{{#unless @last}},{{/unless}}
{{/modulesOfRole}}
{{/ifRule}}
    ]
  }
}
