# Django Endpoint Patterns

## View Structure (DRF ViewSet)

```python
from rest_framework import viewsets, status, serializers
from rest_framework.response import Response
from django.shortcuts import get_object_or_404

from .models import Resource
from .serializers import ResourceSerializer
from .services import ResourceService


class ResourceViewSet(viewsets.ViewSet):
    """ViewSet for Resource CRUD operations."""

    def __init__(self, **kwargs: object) -> None:
        super().__init__(**kwargs)
        self.service = ResourceService()

    def list(self, request) -> Response:
        filters = request.query_params.dict()
        result = self.service.find_all(filters)
        serializer = ResourceSerializer(result, many=True)
        return Response(serializer.data)

    def create(self, request) -> Response:
        serializer = ResourceSerializer(data=request.data)
        serializer.is_valid(raise_exception=True)
        resource = self.service.create(serializer.validated_data)
        return Response(
            ResourceSerializer(resource).data,
            status=status.HTTP_201_CREATED,
        )

    def retrieve(self, request, pk: str | None = None) -> Response:
        resource = self.service.find_by_id(pk)
        serializer = ResourceSerializer(resource)
        return Response(serializer.data)

    def update(self, request, pk: str | None = None) -> Response:
        serializer = ResourceSerializer(data=request.data)
        serializer.is_valid(raise_exception=True)
        resource = self.service.update(pk, serializer.validated_data)
        return Response(ResourceSerializer(resource).data)

    def destroy(self, request, pk: str | None = None) -> Response:
        self.service.remove(pk)
        return Response(status=status.HTTP_204_NO_CONTENT)
```

