# Padroes Django para Endpoints

## Estrutura de View (DRF ViewSet)

```python
from rest_framework import viewsets, status, serializers
from rest_framework.response import Response
from django.shortcuts import get_object_or_404

from .models import Recurso
from .serializers import RecursoSerializer
from .services import RecursoService


class RecursoViewSet(viewsets.ViewSet):
    """ViewSet para operacoes CRUD de Recurso."""

    def __init__(self, **kwargs: object) -> None:
        super().__init__(**kwargs)
        self.service = RecursoService()

    def list(self, request) -> Response:
        filtros = request.query_params.dict()
        resultado = self.service.listar_todos(filtros)
        serializer = RecursoSerializer(resultado, many=True)
        return Response(serializer.data)

    def create(self, request) -> Response:
        serializer = RecursoSerializer(data=request.data)
        serializer.is_valid(raise_exception=True)
        recurso = self.service.criar(serializer.validated_data)
        return Response(
            RecursoSerializer(recurso).data,
            status=status.HTTP_201_CREATED,
        )

    def retrieve(self, request, pk: str | None = None) -> Response:
        recurso = self.service.buscar_por_id(pk)
        serializer = RecursoSerializer(recurso)
        return Response(serializer.data)

    def update(self, request, pk: str | None = None) -> Response:
        serializer = RecursoSerializer(data=request.data)
        serializer.is_valid(raise_exception=True)
        recurso = self.service.atualizar(pk, serializer.validated_data)
        return Response(RecursoSerializer(recurso).data)

    def destroy(self, request, pk: str | None = None) -> Response:
        self.service.remover(pk)
        return Response(status=status.HTTP_204_NO_CONTENT)
```

