# Django Endpoint Testing

## Integration Test with APIClient

```python
import pytest
from rest_framework.test import APIClient
from rest_framework import status
from unittest.mock import patch, MagicMock

from .models import Resource


@pytest.mark.django_db
class TestResourceViewSet:
    def setup_method(self) -> None:
        self.client = APIClient()

    def test_post_resources_should_create_resource(self) -> None:
        data = {"name": "Test", "description": "Test description"}

        response = self.client.post("/api/resources/", data, format="json")

        assert response.status_code == status.HTTP_201_CREATED
        assert response.data["name"] == "Test"
        assert "id" in response.data

    def test_post_resources_should_return_400_for_invalid_body(self) -> None:
        response = self.client.post("/api/resources/", {}, format="json")

        assert response.status_code == status.HTTP_400_BAD_REQUEST

    def test_get_resources_should_list_all(self) -> None:
        Resource.objects.create(name="Resource 1")
        Resource.objects.create(name="Resource 2")

        response = self.client.get("/api/resources/")

        assert response.status_code == status.HTTP_200_OK
        assert len(response.data) == 2

    def test_get_resource_by_id_should_return_resource(self) -> None:
        resource = Resource.objects.create(name="Test")

        response = self.client.get(f"/api/resources/{resource.id}/")

        assert response.status_code == status.HTTP_200_OK
        assert response.data["name"] == "Test"

    def test_get_resource_by_id_should_return_404(self) -> None:
        response = self.client.get("/api/resources/99999/")

        assert response.status_code == status.HTTP_404_NOT_FOUND

    def test_put_resources_should_update_resource(self) -> None:
        resource = Resource.objects.create(name="Old")
        data = {"name": "New", "description": "Updated"}

        response = self.client.put(
            f"/api/resources/{resource.id}/", data, format="json"
        )

        assert response.status_code == status.HTTP_200_OK
        assert response.data["name"] == "New"

    def test_delete_resources_should_remove_resource(self) -> None:
        resource = Resource.objects.create(name="Remove")

        response = self.client.delete(f"/api/resources/{resource.id}/")

        assert response.status_code == status.HTTP_204_NO_CONTENT
        assert not Resource.objects.filter(id=resource.id).exists()
```

## Isolated Serializer Test

```python
from .serializers import ResourceSerializer


class TestResourceSerializer:
    def test_should_validate_correct_data(self) -> None:
        data = {"name": "Valid", "description": "Description"}
        serializer = ResourceSerializer(data=data)

        assert serializer.is_valid()

    def test_should_reject_empty_name(self) -> None:
        data = {"name": "", "description": "Description"}
        serializer = ResourceSerializer(data=data)

        assert not serializer.is_valid()
        assert "name" in serializer.errors
```

## Conventions
- Use DRF `APIClient` for integration tests
- Mark tests with `@pytest.mark.django_db` when accessing the database
- Test HTTP status codes for happy path and errors
- Test serializer in isolation for input validation
- Test create, read, update, and delete endpoints
- Use `format="json"` in client for data submission
