# Testes Django para Endpoints

## Teste de Integracao com APIClient

```python
import pytest
from rest_framework.test import APIClient
from rest_framework import status
from unittest.mock import patch, MagicMock

from .models import Recurso


@pytest.mark.django_db
class TestRecursoViewSet:
    def setup_method(self) -> None:
        self.client = APIClient()

    def test_post_recursos_deve_criar_recurso(self) -> None:
        dados = {"nome": "Teste", "descricao": "Descricao teste"}

        response = self.client.post("/api/recursos/", dados, format="json")

        assert response.status_code == status.HTTP_201_CREATED
        assert response.data["nome"] == "Teste"
        assert "id" in response.data

    def test_post_recursos_deve_retornar_400_para_body_invalido(self) -> None:
        response = self.client.post("/api/recursos/", {}, format="json")

        assert response.status_code == status.HTTP_400_BAD_REQUEST

    def test_get_recursos_deve_listar_todos(self) -> None:
        Recurso.objects.create(nome="Recurso 1")
        Recurso.objects.create(nome="Recurso 2")

        response = self.client.get("/api/recursos/")

        assert response.status_code == status.HTTP_200_OK
        assert len(response.data) == 2

    def test_get_recurso_por_id_deve_retornar_recurso(self) -> None:
        recurso = Recurso.objects.create(nome="Teste")

        response = self.client.get(f"/api/recursos/{recurso.id}/")

        assert response.status_code == status.HTTP_200_OK
        assert response.data["nome"] == "Teste"

    def test_get_recurso_por_id_deve_retornar_404(self) -> None:
        response = self.client.get("/api/recursos/99999/")

        assert response.status_code == status.HTTP_404_NOT_FOUND

    def test_put_recursos_deve_atualizar_recurso(self) -> None:
        recurso = Recurso.objects.create(nome="Antigo")
        dados = {"nome": "Novo", "descricao": "Atualizado"}

        response = self.client.put(
            f"/api/recursos/{recurso.id}/", dados, format="json"
        )

        assert response.status_code == status.HTTP_200_OK
        assert response.data["nome"] == "Novo"

    def test_delete_recursos_deve_remover_recurso(self) -> None:
        recurso = Recurso.objects.create(nome="Remover")

        response = self.client.delete(f"/api/recursos/{recurso.id}/")

        assert response.status_code == status.HTTP_204_NO_CONTENT
        assert not Recurso.objects.filter(id=recurso.id).exists()
```

## Teste de Serializer Isolado

```python
from .serializers import RecursoSerializer


class TestRecursoSerializer:
    def test_deve_validar_dados_corretos(self) -> None:
        dados = {"nome": "Valido", "descricao": "Descricao"}
        serializer = RecursoSerializer(data=dados)

        assert serializer.is_valid()

    def test_deve_rejeitar_nome_vazio(self) -> None:
        dados = {"nome": "", "descricao": "Descricao"}
        serializer = RecursoSerializer(data=dados)

        assert not serializer.is_valid()
        assert "nome" in serializer.errors
```

## Convencoes
- Usar `APIClient` do DRF para testes de integracao
- Marcar testes com `@pytest.mark.django_db` quando acessam banco
- Testar codigos de status HTTP para happy path e erros
- Testar serializer isoladamente para validacao de entrada
- Testar endpoints de criacao, leitura, atualizacao e remocao
- Usar `format="json"` no client para envio de dados
