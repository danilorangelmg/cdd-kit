# Testes Express para Endpoints

## Teste de Integracao com Supertest

```typescript
import request from 'supertest';
import express from 'express';
import recursoRouter from './recurso.router';

describe('Recurso Router', () => {
  let app: express.Application;
  let mockService: any;

  beforeEach(() => {
    mockService = {
      findAll: jest.fn(),
      findOne: jest.fn(),
      create: jest.fn(),
      remove: jest.fn(),
    };

    app = express();
    app.use(express.json());
    app.use('/recursos', recursoRouter(mockService));
    app.use(errorHandler);
  });

  it('POST /recursos - deve criar recurso', async () => {
    mockService.create.mockResolvedValue({ id: '1', nome: 'Teste' });

    const response = await request(app)
      .post('/recursos')
      .send({ nome: 'Teste' })
      .expect(201);

    expect(response.body).toEqual({ id: '1', nome: 'Teste' });
    expect(mockService.create).toHaveBeenCalledWith({ nome: 'Teste' });
  });

  it('POST /recursos - deve retornar 400 para body invalido', async () => {
    await request(app)
      .post('/recursos')
      .send({})
      .expect(400);
  });

  it('GET /recursos/:id - deve retornar 404', async () => {
    mockService.findOne.mockRejectedValue(new NotFoundError('Nao encontrado'));

    await request(app)
      .get('/recursos/999')
      .expect(404);
  });
});
```

## Teste de Middleware Isolado

```typescript
describe('validate middleware', () => {
  it('deve chamar next() quando validacao passa', () => {
    const req = { body: { nome: 'valido' } } as Request;
    const res = { status: jest.fn().mockReturnThis(), json: jest.fn() } as any;
    const next = jest.fn();

    validate(req, res, next);
    expect(next).toHaveBeenCalled();
  });
});
```

## Convencoes
- Criar app Express fresco em cada `beforeEach`
- Mockar service via factory function do router
- Testar codigos de status HTTP para happy path e erros
- Testar middleware de validacao isoladamente
- Testar error handler com diferentes tipos de erro
- Sempre incluir `express.json()` no app de teste
