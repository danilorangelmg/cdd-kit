# Express Endpoint Testing

## Integration Test with Supertest

```typescript
import request from 'supertest';
import express from 'express';
import resourceRouter from './resource.router';

describe('Resource Router', () => {
  let app: express.Application;
  let mockService: any;

  beforeEach(() => {
    mockService = {
      findAll: jest.fn(),
      findOne: jest.fn(),
      create: jest.fn(),
      remove: jest.fn(),
    };

    app = express();
    app.use(express.json());
    app.use('/resources', resourceRouter(mockService));
    app.use(errorHandler);
  });

  it('POST /resources - should create resource', async () => {
    mockService.create.mockResolvedValue({ id: '1', name: 'Test' });

    const response = await request(app)
      .post('/resources')
      .send({ name: 'Test' })
      .expect(201);

    expect(response.body).toEqual({ id: '1', name: 'Test' });
    expect(mockService.create).toHaveBeenCalledWith({ name: 'Test' });
  });

  it('POST /resources - should return 400 for invalid body', async () => {
    await request(app)
      .post('/resources')
      .send({})
      .expect(400);
  });

  it('GET /resources/:id - should return 404', async () => {
    mockService.findOne.mockRejectedValue(new NotFoundError('Not found'));

    await request(app)
      .get('/resources/999')
      .expect(404);
  });
});
```

## Isolated Middleware Test

```typescript
describe('validate middleware', () => {
  it('should call next() when validation passes', () => {
    const req = { body: { name: 'valid' } } as Request;
    const res = { status: jest.fn().mockReturnThis(), json: jest.fn() } as any;
    const next = jest.fn();

    validate(req, res, next);
    expect(next).toHaveBeenCalled();
  });
});
```

## Conventions
- Create fresh Express app in each `beforeEach`
- Mock service via router factory function
- Test HTTP status codes for happy path and errors
- Test validation middleware in isolation
- Test error handler with different error types
- Always include `express.json()` in test app
