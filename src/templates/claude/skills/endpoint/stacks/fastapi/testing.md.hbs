# Testes FastAPI para Endpoints

## Teste de Integracao com httpx

```python
import pytest
from httpx import AsyncClient, ASGITransport
from fastapi import FastAPI

from recurso.router import router
from recurso.service import RecursoService


@pytest.fixture
def mock_servico(mocker):
    return mocker.AsyncMock(spec=RecursoService)


@pytest.fixture
def app(mock_servico):
    app = FastAPI()
    app.include_router(router)
    app.dependency_overrides[get_recurso_service] = lambda: mock_servico
    return app


@pytest.fixture
async def client(app):
    transport = ASGITransport(app=app)
    async with AsyncClient(transport=transport, base_url="http://test") as cliente:
        yield cliente


@pytest.mark.asyncio
async def test_criar_recurso(client, mock_servico):
    mock_servico.create.return_value = {"id": "1", "nome": "Teste"}

    resposta = await client.post("/recursos", json={"nome": "Teste"})

    assert resposta.status_code == 201
    assert resposta.json() == {"id": "1", "nome": "Teste"}
    mock_servico.create.assert_called_once()


@pytest.mark.asyncio
async def test_criar_recurso_body_invalido(client):
    resposta = await client.post("/recursos", json={})

    assert resposta.status_code == 422


@pytest.mark.asyncio
async def test_obter_recurso_nao_encontrado(client, mock_servico):
    mock_servico.find_one.return_value = None

    resposta = await client.get("/recursos/999")

    assert resposta.status_code == 404
```

## Teste com TestClient (sincrono)

```python
from fastapi.testclient import TestClient


def test_listar_recursos(app, mock_servico):
    mock_servico.find_all.return_value = [{"id": "1", "nome": "Teste"}]
    client = TestClient(app)

    resposta = client.get("/recursos")

    assert resposta.status_code == 200
    assert len(resposta.json()) == 1
```

## Convencoes
- Usar `dependency_overrides` para injetar mock do service
- `httpx.AsyncClient` com `ASGITransport` para testes async
- `TestClient` para testes sincronos simples
- Testar codigos de status HTTP para happy path e erros
- Testar validacao Pydantic (422 para body invalido)
- Criar app FastAPI fresco em cada fixture
- Sempre limpar `dependency_overrides` apos os testes
