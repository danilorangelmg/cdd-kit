# Fastify Endpoint Patterns

## Route Structure with Schema

```typescript
import { FastifyInstance, FastifyRequest, FastifyReply } from 'fastify';

const resourceSchema = {
  body: {
    type: 'object',
    required: ['name'],
    properties: {
      name: { type: 'string', minLength: 1 },
      description: { type: 'string' },
    },
    additionalProperties: false,
  },
  response: {
    201: {
      type: 'object',
      properties: {
        id: { type: 'string' },
        name: { type: 'string' },
      },
    },
  },
};

export default async function resourceRoutes(fastify: FastifyInstance) {
  fastify.get('/', async (request, reply) => {
    return fastify.resourceService.findAll(request.query);
  });

  fastify.get('/:id', async (request: FastifyRequest<{ Params: { id: string } }>, reply) => {
    return fastify.resourceService.findOne(request.params.id);
  });

  fastify.post('/', { schema: resourceSchema }, async (request, reply) => {
    const resource = await fastify.resourceService.create(request.body);
    reply.code(201).send(resource);
  });

  fastify.delete('/:id', async (request: FastifyRequest<{ Params: { id: string } }>, reply) => {
    await fastify.resourceService.remove(request.params.id);
    reply.code(204).send();
  });
}
```

## Service Plugin with Decorator

```typescript
import fp from 'fastify-plugin';

export default fp(async function (fastify) {
  const service = new ResourceService(fastify.db);
  fastify.decorate('resourceService', service);
});
```

## Hooks

```typescript
export default async function resourceRoutes(fastify: FastifyInstance) {
  // Route-level hook
  fastify.addHook('onRequest', async (request, reply) => {
    await request.authenticate();
  });

  fastify.addHook('preHandler', async (request, reply) => {
    // additional validation, logging
  });

  // routes here...
}
```

## Route Registration

```typescript
// app.ts
fastify.register(resourceRoutes, { prefix: '/api/resources' });
```

## Conventions
- Validation via JSON Schema in the route `schema` object (automatic)
- Serialization via `response` schema for performance
- Encapsulated plugins with `fastify-plugin` when shared
- Hooks (`onRequest`, `preHandler`) for auth and pre-processing
- Decorators to inject services into the Fastify instance
- Async handlers — no callbacks, return value directly
- Encapsulation: plugins registered in isolated scope by default
