# Padroes Fastify para Endpoints

## Estrutura de Rota com Schema

```typescript
import { FastifyInstance, FastifyRequest, FastifyReply } from 'fastify';

const recursoSchema = {
  body: {
    type: 'object',
    required: ['nome'],
    properties: {
      nome: { type: 'string', minLength: 1 },
      descricao: { type: 'string' },
    },
    additionalProperties: false,
  },
  response: {
    201: {
      type: 'object',
      properties: {
        id: { type: 'string' },
        nome: { type: 'string' },
      },
    },
  },
};

export default async function recursoRoutes(fastify: FastifyInstance) {
  fastify.get('/', async (request, reply) => {
    return fastify.recursoService.findAll(request.query);
  });

  fastify.get('/:id', async (request: FastifyRequest<{ Params: { id: string } }>, reply) => {
    return fastify.recursoService.findOne(request.params.id);
  });

  fastify.post('/', { schema: recursoSchema }, async (request, reply) => {
    const recurso = await fastify.recursoService.create(request.body);
    reply.code(201).send(recurso);
  });

  fastify.delete('/:id', async (request: FastifyRequest<{ Params: { id: string } }>, reply) => {
    await fastify.recursoService.remove(request.params.id);
    reply.code(204).send();
  });
}
```

## Plugin de Servico com Decorator

```typescript
import fp from 'fastify-plugin';

export default fp(async function (fastify) {
  const service = new RecursoService(fastify.db);
  fastify.decorate('recursoService', service);
});
```

## Hooks

```typescript
export default async function recursoRoutes(fastify: FastifyInstance) {
  // Hook no nivel da rota
  fastify.addHook('onRequest', async (request, reply) => {
    await request.authenticate();
  });

  fastify.addHook('preHandler', async (request, reply) => {
    // validacao adicional, logging
  });

  // rotas aqui...
}
```

## Registro de Rotas

```typescript
// app.ts
fastify.register(recursoRoutes, { prefix: '/api/recursos' });
```

## Convencoes
- Validacao via JSON Schema no objeto `schema` da rota (automatico)
- Serialization via `response` schema para performance
- Plugins encapsulados com `fastify-plugin` quando compartilhados
- Hooks (`onRequest`, `preHandler`) para auth e pre-processamento
- Decorators para injetar services na instancia Fastify
- Async handlers — sem callback, retornar valor diretamente
- Encapsulamento: plugins registrados em escopo isolado por padrao
