# Fastify Endpoint Testing

## Testing with fastify.inject()

```typescript
import Fastify from 'fastify';
import resourceRoutes from './resource.routes';
import resourceServicePlugin from './resource.service.plugin';

describe('Resource Routes', () => {
  let fastify: ReturnType<typeof Fastify>;

  beforeEach(async () => {
    fastify = Fastify();

    // Register mock service as decorator
    fastify.decorate('resourceService', {
      findAll: jest.fn(),
      findOne: jest.fn(),
      create: jest.fn(),
      remove: jest.fn(),
    });

    fastify.register(resourceRoutes, { prefix: '/resources' });
    await fastify.ready();
  });

  afterEach(async () => {
    await fastify.close();
  });

  it('POST /resources - should create resource', async () => {
    const service = fastify.resourceService as any;
    service.create.mockResolvedValue({ id: '1', name: 'Test' });

    const response = await fastify.inject({
      method: 'POST',
      url: '/resources',
      payload: { name: 'Test' },
    });

    expect(response.statusCode).toBe(201);
    expect(response.json()).toEqual({ id: '1', name: 'Test' });
  });

  it('POST /resources - should reject invalid payload', async () => {
    const response = await fastify.inject({
      method: 'POST',
      url: '/resources',
      payload: {},
    });

    expect(response.statusCode).toBe(400);
  });

  it('GET /resources/:id - should return resource', async () => {
    const service = fastify.resourceService as any;
    service.findOne.mockResolvedValue({ id: '1', name: 'Test' });

    const response = await fastify.inject({
      method: 'GET',
      url: '/resources/1',
    });

    expect(response.statusCode).toBe(200);
    expect(response.json()).toEqual({ id: '1', name: 'Test' });
  });
});
```

## Plugin Testing

```typescript
it('should register plugin without error', async () => {
  const app = Fastify();
  app.register(resourceServicePlugin);
  await app.ready();
  expect(app.resourceService).toBeDefined();
  await app.close();
});
```

## Conventions
- Use `fastify.inject()` — no network port needed
- Call `fastify.ready()` before tests
- Always call `fastify.close()` in `afterEach`
- Mock services via `decorate` before registering routes
- Route schema validates automatically — test rejections
- Use `response.json()` to parse body
