## Essential RxJS Operators

```ts
import {
  map, switchMap, combineLatest, distinctUntilChanged,
  debounceTime, catchError, tap, shareReplay,
} from "rxjs";

@Injectable({ providedIn: "root" })
export class SearchService {
  private query$ = new BehaviorSubject<string>("");

  // switchMap â€” cancels previous request
  readonly results$ = this.query$.pipe(
    debounceTime(300),
    distinctUntilChanged(),
    switchMap((query) =>
      query.length < 2
        ? of([])
        : this.http.get<Item[]>(`/api/search?q=${query}`)
    ),
    shareReplay(1),
    catchError(() => of([]))
  );

  // combineLatest â€” combine streams
  readonly viewModel$ = combineLatest([
    this.users$,
    this.filters$,
