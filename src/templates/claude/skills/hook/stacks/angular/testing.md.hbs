# Angular Service Testing Patterns

## Base Structure (TestBed.inject)

```ts
import { TestBed } from "@angular/core/testing";
import { HttpClientTestingModule, HttpTestingController } from "@angular/common/http/testing";
import { UserService } from "./user.service";

describe("UserService", () => {
  let service: UserService;
  let httpMock: HttpTestingController;

  beforeEach(() => {
    TestBed.configureTestingModule({
      imports: [HttpClientTestingModule],
      providers: [UserService],
    });

    service = TestBed.inject(UserService);
    httpMock = TestBed.inject(HttpTestingController);
  });

  afterEach(() => {
    httpMock.verify();
  });

  it("should load users", () => {
    const mockUsers = [{ id: "1", name: "Maria" }];

    service.loadUsers();
    const req = httpMock.expectOne("/api/users");
    req.flush(mockUsers);

    service.users$.subscribe((users) => {
      expect(users).toEqual(mockUsers);
    });
  });
});
```

## fakeAsync / tick

```ts
import { fakeAsync, tick } from "@angular/core/testing";

it("debounces search", fakeAsync(() => {
  service.search("test");
  tick(100); // still within debounce
  expect(lastResult).toBeUndefined();

  tick(300); // debounce complete
  const req = httpMock.expectOne("/api/search?q=test");
  req.flush([{ name: "Test Item" }]);

  service.results$.subscribe((results) => {
    expect(results).toHaveLength(1);
  });
}));
```

## Testing BehaviorSubject / State

```ts
it("updates loading state", () => {
  const loadingStates: boolean[] = [];
  service.loading$.subscribe((l) => loadingStates.push(l));

  service.loadUsers();
  expect(loadingStates).toContain(true);

  const req = httpMock.expectOne("/api/users");
  req.flush([]);

  expect(loadingStates[loadingStates.length - 1]).toBe(false);
});
```

## Testing Errors

```ts
it("handles HTTP error", () => {
  service.loadUsers();

  const req = httpMock.expectOne("/api/users");
  req.error(new ProgressEvent("error"), { status: 500 });

  service.error$.subscribe((error) => {
    expect(error).toBeTruthy();
  });
