# Flutter State Testing

## Testing ChangeNotifier

```dart
import 'package:flutter_test/flutter_test.dart';
import 'package:my_app/notifiers/counter_notifier.dart';

void main() {
  late CounterNotifier notifier;

  setUp(() {
    notifier = CounterNotifier();
  });

  test('initial value is zero', () {
    expect(notifier.count, 0);
  });

  test('increment increases counter', () {
    notifier.increment();
    expect(notifier.count, 1);
  });

  test('decrement does not go below zero', () {
    notifier.decrement();
    expect(notifier.count, 0);
  });

  test('notifies listeners on change', () {
    var notified = false;
    notifier.addListener(() => notified = true);
    notifier.increment();
    expect(notified, isTrue);
  });
}
```

