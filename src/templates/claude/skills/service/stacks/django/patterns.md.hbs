# Django Service Patterns

## Class-Based Service

```python
from django.db import transaction

from .models import Resource
from .exceptions import NotFoundError


class ResourceService:
    """Service for Resource domain operations."""

    def find_all(self, filters: dict | None = None) -> list[Resource]:
        queryset = Resource.objects.all()
        if filters:
            queryset = queryset.filter(**filters)
        return list(queryset)

    def find_by_id(self, id: int) -> Resource:
        try:
            return Resource.objects.get(pk=id)
        except Resource.DoesNotExist:
            raise NotFoundError(f"Resource {id} not found")

    def create(self, data: dict) -> Resource:
        return Resource.objects.create(**data)

    @transaction.atomic
    def update(self, id: int, data: dict) -> Resource:
        resource = self.find_by_id(id)
        for field, value in data.items():
            setattr(resource, field, value)
        resource.save()
        return resource

    @transaction.atomic
    def remove(self, id: int) -> None:
        resource = self.find_by_id(id)
        resource.delete()
```

## Manager/QuerySet Pattern

```python
from django.db import models


class ResourceQuerySet(models.QuerySet):
    def active(self) -> "ResourceQuerySet":
        return self.filter(is_active=True)

    def by_category(self, category: str) -> "ResourceQuerySet":
        return self.filter(category=category)


class ResourceManager(models.Manager):
    def get_queryset(self) -> ResourceQuerySet:
        return ResourceQuerySet(self.model, using=self._db)

    def active(self) -> ResourceQuerySet:
        return self.get_queryset().active()


class Resource(models.Model):
    name = models.CharField(max_length=255)
    category = models.CharField(max_length=100)
    is_active = models.BooleanField(default=True)
    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)

    objects = ResourceManager()

    class Meta:
        ordering = ["-created_at"]
```

## Composed Transactions

```python
from django.db import transaction


class OrderService:
    """Service with composed transactional operations."""

    @transaction.atomic
    def create_order_with_items(
        self,
        order_data: dict,
        items: list[dict],
    ) -> "Order":
        order = Order.objects.create(**order_data)
        for item_data in items:
            OrderItem.objects.create(order=order, **item_data)
        order.calculate_total()
        order.save()
        return order
```

## Domain Errors

```python
class NotFoundError(Exception):
    """Raised when entity is not found."""
    pass


class ValidationError(Exception):
    """Raised when a business rule is violated."""
    pass


class OperationNotAllowedError(Exception):
    """Raised when operation is not allowed in current state."""
    pass
```

## Conventions
- Service as plain Python class (no framework inheritance)
- Custom Manager/QuerySet for reusable model queries
- `transaction.atomic()` for operations that modify multiple records
- Custom domain errors (don't use HTTP errors in the service)
- Service doesn't know DRF (no Request/Response)
- One service per domain, single-responsibility methods
