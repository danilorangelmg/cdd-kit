# FastAPI Service Patterns

## Class-Based Service

```python
from typing import Optional


class ResourceService:
    def __init__(self, repository: ResourceRepository) -> None:
        self._repository = repository

    async def find_all(self, filters: Optional[ListResourceFilters] = None) -> list[Resource]:
        return await self._repository.find_many(filters)

    async def find_one(self, id: str) -> Resource:
        resource = await self._repository.find_by_id(id)
        if not resource:
            raise NotFoundError(f"Resource {id} not found")
        return resource

    async def create(self, data: ResourceCreateInput) -> Resource:
        return await self._repository.create(data)

    async def update(self, id: str, data: ResourceUpdateInput) -> Resource:
        await self.find_one(id)
        return await self._repository.update(id, data)

    async def remove(self, id: str) -> None:
        await self.find_one(id)
        await self._repository.delete(id)
```

## Dependency Injection via Depends

```python
from fastapi import Depends


def get_repository() -> ResourceRepository:
    db = get_database()
    return SQLAlchemyResourceRepository(db)


def get_resource_service(
    repository: ResourceRepository = Depends(get_repository),
) -> ResourceService:
    return ResourceService(repository)


# In the router
@router.get("/")
async def list_resources(service: ResourceService = Depends(get_resource_service)):
    return await service.find_all()
```

## Protocol Pattern for Repository

```python
from typing import Protocol, Optional


class ResourceRepository(Protocol):
    async def find_many(self, filters: Optional[ListResourceFilters] = None) -> list[Resource]: ...
    async def find_by_id(self, id: str) -> Optional[Resource]: ...
    async def create(self, data: ResourceCreateInput) -> Resource: ...
    async def update(self, id: str, data: ResourceUpdateInput) -> Resource: ...
    async def delete(self, id: str) -> None: ...


# Implementation
class SQLAlchemyResourceRepository:
    def __init__(self, session: AsyncSession) -> None:
        self._session = session

    async def find_by_id(self, id: str) -> Optional[Resource]:
        result = await self._session.get(ResourceModel, id)
        return result
    # ...other methods
```

## Domain Errors

```python
class NotFoundError(Exception):
    def __init__(self, message: str) -> None:
        self.message = message
        super().__init__(message)


class DomainValidationError(Exception):
    def __init__(self, message: str) -> None:
        self.message = message
        super().__init__(message)
```

## Conventions
- Service receives dependencies via constructor (no decorators)
- FastAPI `Depends()` for composition at the route layer
- `Protocol` for repository interface (structural typing)
- Custom domain errors (don't use HTTP errors)
- Service doesn't know FastAPI (no Request/Response)
- One service per domain, single-responsibility methods
- All methods async with explicit return types
