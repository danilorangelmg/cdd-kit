# Padroes FastAPI para Services

## Service Baseado em Classe

```python
from typing import Optional


class RecursoService:
    def __init__(self, repository: RecursoRepository) -> None:
        self._repository = repository

    async def find_all(self, filtros: Optional[ListRecursoFiltros] = None) -> list[Recurso]:
        return await self._repository.find_many(filtros)

    async def find_one(self, id: str) -> Recurso:
        recurso = await self._repository.find_by_id(id)
        if not recurso:
            raise NotFoundError(f"Recurso {id} nao encontrado")
        return recurso

    async def create(self, dados: RecursoCriarInput) -> Recurso:
        return await self._repository.create(dados)

    async def update(self, id: str, dados: RecursoAtualizarInput) -> Recurso:
        await self.find_one(id)
        return await self._repository.update(id, dados)

    async def remove(self, id: str) -> None:
        await self.find_one(id)
        await self._repository.delete(id)
```

## Injecao de Dependencias via Depends

```python
from fastapi import Depends


def get_repository() -> RecursoRepository:
    db = get_database()
    return SQLAlchemyRecursoRepository(db)


def get_recurso_service(
    repository: RecursoRepository = Depends(get_repository),
) -> RecursoService:
    return RecursoService(repository)


# No router
@router.get("/")
async def listar(servico: RecursoService = Depends(get_recurso_service)):
    return await servico.find_all()
```

## Padrao Protocol para Repositorio

```python
from typing import Protocol, Optional


class RecursoRepository(Protocol):
    async def find_many(self, filtros: Optional[ListRecursoFiltros] = None) -> list[Recurso]: ...
    async def find_by_id(self, id: str) -> Optional[Recurso]: ...
    async def create(self, dados: RecursoCriarInput) -> Recurso: ...
    async def update(self, id: str, dados: RecursoAtualizarInput) -> Recurso: ...
    async def delete(self, id: str) -> None: ...


# Implementacao
class SQLAlchemyRecursoRepository:
    def __init__(self, session: AsyncSession) -> None:
        self._session = session

    async def find_by_id(self, id: str) -> Optional[Recurso]:
        resultado = await self._session.get(RecursoModel, id)
        return resultado
    # ...demais metodos
```

## Erros de Dominio

```python
class NotFoundError(Exception):
    def __init__(self, message: str) -> None:
        self.message = message
        super().__init__(message)


class DomainValidationError(Exception):
    def __init__(self, message: str) -> None:
        self.message = message
        super().__init__(message)
```

## Convencoes
- Service recebe dependencias via construtor (sem decorators)
- `Depends()` do FastAPI para composicao na camada de rota
- `Protocol` para interface de repositorio (tipagem estrutural)
- Erros de dominio customizados (sem usar erros HTTP)
- Service nao conhece FastAPI (sem Request/Response)
- Um service por dominio, metodos com responsabilidade unica
- Todos os metodos async com tipagem de retorno explicita
