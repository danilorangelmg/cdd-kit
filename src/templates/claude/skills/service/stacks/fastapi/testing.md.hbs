# FastAPI Service Testing

## Direct Instantiation with Mocks

```python
import pytest
from unittest.mock import AsyncMock

from resource.service import ResourceService
from resource.repository import ResourceRepository
from resource.errors import NotFoundError


@pytest.fixture
def mock_repository():
    repository = AsyncMock(spec=ResourceRepository)
    repository.find_many = AsyncMock(return_value=[])
    repository.find_by_id = AsyncMock(return_value=None)
    repository.create = AsyncMock()
    repository.update = AsyncMock()
    repository.delete = AsyncMock()
    return repository


@pytest.fixture
def service(mock_repository):
    return ResourceService(mock_repository)
```

## Method Tests

```python
@pytest.mark.asyncio
async def test_find_one_found(service, mock_repository):
    resource = {"id": "1", "name": "Test"}
    mock_repository.find_by_id.return_value = resource

    result = await service.find_one("1")

    assert result == resource
    mock_repository.find_by_id.assert_called_once_with("1")


@pytest.mark.asyncio
async def test_find_one_not_found(service, mock_repository):
    mock_repository.find_by_id.return_value = None

    with pytest.raises(NotFoundError):
        await service.find_one("999")


@pytest.mark.asyncio
async def test_create_resource(service, mock_repository):
    data = {"name": "New"}
    created = {"id": "1", **data}
    mock_repository.create.return_value = created

    result = await service.create(data)

    assert result == created
    mock_repository.create.assert_called_once_with(data)


@pytest.mark.asyncio
async def test_update_verifies_existence(service, mock_repository):
    mock_repository.find_by_id.return_value = None

    with pytest.raises(NotFoundError):
        await service.update("999", {"name": "X"})

    mock_repository.update.assert_not_called()
```

## Test Data Factory

```python
from resource.model import Resource
from datetime import datetime


def create_resource(**override) -> dict:
    defaults = {
        "id": "1",
        "name": "Default Resource",
        "created_at": datetime(2024, 1, 1),
    }
    return {**defaults, **override}
```

## Conventions
- Instantiate service directly with `ResourceService(mock_repository)`
- Mock repository via `AsyncMock(spec=ResourceRepository)`
- Test each public method in isolation with `pytest.mark.asyncio`
- Test custom domain error throwing with `pytest.raises`
- Verify repository is not called in error scenarios
- Use factory functions for reusable test data
- No FastAPI mocks (service doesn't know HTTP)
