# Padroes Fastify para Services

## Service como Plugin

```typescript
import fp from 'fastify-plugin';
import { FastifyInstance } from 'fastify';

export class RecursoService {
  constructor(private readonly repository: RecursoRepository) {}

  async findAll(filtros?: ListRecursoFiltros): Promise<Recurso[]> {
    return this.repository.findMany(filtros);
  }

  async findOne(id: string): Promise<Recurso> {
    const recurso = await this.repository.findById(id);
    if (!recurso) {
      throw new NotFoundError(`Recurso ${id} nao encontrado`);
    }
    return recurso;
  }

  async create(dados: CreateRecursoInput): Promise<Recurso> {
    return this.repository.create(dados);
  }

  async update(id: string, dados: UpdateRecursoInput): Promise<Recurso> {
    await this.findOne(id);
    return this.repository.update(id, dados);
  }

  async remove(id: string): Promise<void> {
    await this.findOne(id);
    await this.repository.delete(id);
  }
}

// Plugin que registra o service
export default fp(async function recursoServicePlugin(fastify: FastifyInstance) {
  const repository = new PrismaRecursoRepository(fastify.prisma);
  const service = new RecursoService(repository);
  fastify.decorate('recursoService', service);
});
```

## Decorators e Tipagem

```typescript
// Declaracao de tipos para o decorator
declare module 'fastify' {
  interface FastifyInstance {
    recursoService: RecursoService;
  }
}
```

## Encapsulamento

```typescript
// Plugin encapsulado — visivel apenas no escopo de registro
async function recursoPlugin(fastify: FastifyInstance) {
  const service = new RecursoService(fastify.db);
  fastify.decorate('recursoService', service);

  // Rotas que usam o service
  fastify.get('/', async () => service.findAll());
}

// Plugin compartilhado — visivel em toda a aplicacao
export default fp(async function sharedPlugin(fastify: FastifyInstance) {
  fastify.decorate('sharedService', new SharedService());
});
```

## Acesso a Dependencias via Fastify

```typescript
export default fp(async function pedidoServicePlugin(fastify: FastifyInstance) {
  // Acessar outros services via decorators do Fastify
  const service = new PedidoService(
    fastify.pedidoRepository,
    fastify.estoqueService,
    fastify.notificacaoService,
  );
  fastify.decorate('pedidoService', service);
});
```

## Convencoes
- Service e classe pura — logica de negocio sem Fastify
- Plugin (`fp`) registra e expoe o service via `decorate`
- `fastify-plugin` (`fp`) para plugins que devem ser compartilhados
- Sem `fp` para plugins encapsulados (escopo isolado)
- Declarar tipos com `declare module 'fastify'`
- Dependencias acessadas via decorators da instancia Fastify
- Service nao conhece HTTP (sem request/reply)
