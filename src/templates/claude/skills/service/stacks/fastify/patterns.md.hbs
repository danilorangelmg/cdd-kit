# Fastify Service Patterns

## Service as Plugin

```typescript
import fp from 'fastify-plugin';
import { FastifyInstance } from 'fastify';

export class ResourceService {
  constructor(private readonly repository: ResourceRepository) {}

  async findAll(filters?: ListResourceFilters): Promise<Resource[]> {
    return this.repository.findMany(filters);
  }

  async findOne(id: string): Promise<Resource> {
    const resource = await this.repository.findById(id);
    if (!resource) {
      throw new NotFoundError(`Resource ${id} not found`);
    }
    return resource;
  }

  async create(data: CreateResourceInput): Promise<Resource> {
    return this.repository.create(data);
  }

  async update(id: string, data: UpdateResourceInput): Promise<Resource> {
    await this.findOne(id);
    return this.repository.update(id, data);
  }

  async remove(id: string): Promise<void> {
    await this.findOne(id);
    await this.repository.delete(id);
  }
}

// Plugin that registers the service
export default fp(async function resourceServicePlugin(fastify: FastifyInstance) {
  const repository = new PrismaResourceRepository(fastify.prisma);
  const service = new ResourceService(repository);
  fastify.decorate('resourceService', service);
});
```

## Decorators and Typing

```typescript
// Type declaration for the decorator
declare module 'fastify' {
  interface FastifyInstance {
    resourceService: ResourceService;
  }
}
```

## Encapsulation

```typescript
// Encapsulated plugin — visible only in registration scope
async function resourcePlugin(fastify: FastifyInstance) {
  const service = new ResourceService(fastify.db);
  fastify.decorate('resourceService', service);

  // Routes that use the service
  fastify.get('/', async () => service.findAll());
}

// Shared plugin — visible across the entire application
export default fp(async function sharedPlugin(fastify: FastifyInstance) {
  fastify.decorate('sharedService', new SharedService());
});
```

## Accessing Dependencies via Fastify

```typescript
export default fp(async function orderServicePlugin(fastify: FastifyInstance) {
  // Access other services via Fastify decorators
  const service = new OrderService(
    fastify.orderRepository,
    fastify.inventoryService,
    fastify.notificationService,
  );
  fastify.decorate('orderService', service);
});
```

## Conventions
- Service is a pure class — business logic without Fastify
- Plugin (`fp`) registers and exposes the service via `decorate`
- `fastify-plugin` (`fp`) for plugins that should be shared
- Without `fp` for encapsulated plugins (isolated scope)
- Declare types with `declare module 'fastify'`
- Dependencies accessed via Fastify instance decorators
- Service doesn't know HTTP (no request/reply)
