# Padroes Flask para Services

## Service Baseado em Classe

```python
from dataclasses import dataclass


class RecursoService:
    def __init__(self, repository: "RecursoRepository") -> None:
        self._repository = repository

    def find_all(self, filtros: dict | None = None) -> list[dict]:
        return self._repository.find_many(filtros)

    def find_one(self, recurso_id: str) -> dict:
        recurso = self._repository.find_by_id(recurso_id)
        if recurso is None:
            raise NotFoundError(f"Recurso {recurso_id} nao encontrado")
        return recurso

    def create(self, dados: dict) -> dict:
        return self._repository.create(dados)

    def update(self, recurso_id: str, dados: dict) -> dict:
        self.find_one(recurso_id)
        return self._repository.update(recurso_id, dados)

    def remove(self, recurso_id: str) -> None:
        self.find_one(recurso_id)
        self._repository.delete(recurso_id)
```

## Padrao Repository

```python
from abc import ABC, abstractmethod


class RecursoRepository(ABC):
    @abstractmethod
    def find_many(self, filtros: dict | None = None) -> list[dict]:
        ...

    @abstractmethod
    def find_by_id(self, recurso_id: str) -> dict | None:
        ...

    @abstractmethod
    def create(self, dados: dict) -> dict:
        ...

    @abstractmethod
    def update(self, recurso_id: str, dados: dict) -> dict:
        ...

    @abstractmethod
    def delete(self, recurso_id: str) -> None:
        ...


class SQLAlchemyRecursoRepository(RecursoRepository):
    def __init__(self, session: "Session") -> None:
        self._session = session

    def find_by_id(self, recurso_id: str) -> dict | None:
        recurso = self._session.get(RecursoModel, recurso_id)
        return recurso.to_dict() if recurso else None

    # ...demais metodos
```

