# Flask Service Patterns

## Class-Based Service

```python
from dataclasses import dataclass


class ResourceService:
    def __init__(self, repository: "ResourceRepository") -> None:
        self._repository = repository

    def find_all(self, filters: dict | None = None) -> list[dict]:
        return self._repository.find_many(filters)

    def find_one(self, resource_id: str) -> dict:
        resource = self._repository.find_by_id(resource_id)
        if resource is None:
            raise NotFoundError(f"Resource {resource_id} not found")
        return resource

    def create(self, data: dict) -> dict:
        return self._repository.create(data)

    def update(self, resource_id: str, data: dict) -> dict:
        self.find_one(resource_id)
        return self._repository.update(resource_id, data)

    def remove(self, resource_id: str) -> None:
        self.find_one(resource_id)
        self._repository.delete(resource_id)
```

## Repository Pattern

```python
from abc import ABC, abstractmethod


class ResourceRepository(ABC):
    @abstractmethod
    def find_many(self, filters: dict | None = None) -> list[dict]:
        ...

    @abstractmethod
    def find_by_id(self, resource_id: str) -> dict | None:
        ...

    @abstractmethod
    def create(self, data: dict) -> dict:
        ...

    @abstractmethod
    def update(self, resource_id: str, data: dict) -> dict:
        ...

    @abstractmethod
    def delete(self, resource_id: str) -> None:
        ...


class SQLAlchemyResourceRepository(ResourceRepository):
    def __init__(self, session: "Session") -> None:
        self._session = session

    def find_by_id(self, resource_id: str) -> dict | None:
        resource = self._session.get(ResourceModel, resource_id)
        return resource.to_dict() if resource else None

    # ...other methods
```

