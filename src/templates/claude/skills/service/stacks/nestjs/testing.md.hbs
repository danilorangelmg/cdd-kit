# NestJS Service Testing

## Test Module Setup

```typescript
import { Test, TestingModule } from '@nestjs/testing';
import { NotFoundException } from '@nestjs/common';

describe('ResourceService', () => {
  let service: ResourceService;
  let repository: jest.Mocked<ResourceRepository>;

  beforeEach(async () => {
    const mockRepository = {
      findMany: jest.fn(),
      findById: jest.fn(),
      create: jest.fn(),
      update: jest.fn(),
      delete: jest.fn(),
    };

    const module: TestingModule = await Test.createTestingModule({
      providers: [
        ResourceService,
        {
          provide: 'RESOURCE_REPOSITORY',
          useValue: mockRepository,
        },
      ],
    }).compile();

    service = module.get<ResourceService>(ResourceService);
    repository = module.get('RESOURCE_REPOSITORY');
  });
```

## Method Tests

```typescript
  describe('findOne', () => {
    it('should return resource when found', async () => {
      const resource = { id: '1', name: 'Test' };
      repository.findById.mockResolvedValue(resource);

      const result = await service.findOne('1');
      expect(result).toEqual(resource);
    });

    it('should throw NotFoundException when not found', async () => {
      repository.findById.mockResolvedValue(null);

      await expect(service.findOne('999')).rejects.toThrow(NotFoundException);
    });
  });

  describe('create', () => {
    it('should create and return resource', async () => {
      const dto = { name: 'New' };
      const created = { id: '1', ...dto };
      repository.create.mockResolvedValue(created);

      const result = await service.create(dto);
      expect(result).toEqual(created);
      expect(repository.create).toHaveBeenCalledWith(dto);
    });
  });
});
```

## Override Provider

```typescript
const module = await Test.createTestingModule({
  imports: [ResourceModule],
})
  .overrideProvider('RESOURCE_REPOSITORY')
  .useValue(mockRepository)
  .compile();
```

## Conventions
- `Test.createTestingModule` to configure isolated providers
- Mock repositories with `jest.fn()` in provider
- `overrideProvider` when importing the full module
- Test each public method in isolation
- Test exception throwing (`rejects.toThrow`)
- Verify repository calls (`toHaveBeenCalledWith`)
- Don't test internal implementation, test behavior
