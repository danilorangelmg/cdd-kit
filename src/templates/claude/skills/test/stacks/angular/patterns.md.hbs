## Test Structure (Component)

```ts
import { ComponentFixture, TestBed } from "@angular/core/testing";
import { By } from "@angular/platform-browser";
import { ButtonComponent } from "./button.component";

describe("ButtonComponent", () => {
  let component: ButtonComponent;
  let fixture: ComponentFixture<ButtonComponent>;

  beforeEach(async () => {
    await TestBed.configureTestingModule({
      imports: [ButtonComponent],
    }).compileComponents();

    fixture = TestBed.createComponent(ButtonComponent);
    component = fixture.componentInstance;
    fixture.detectChanges();
  });

  it("should create", () => {
    expect(component).toBeTruthy();
  });

  it("should render with variant", () => {
    component.variant = "outline";
    fixture.detectChanges();

    const el = fixture.debugElement.query(By.css("button"));
    expect(el.nativeElement.className).toContain("btn--outline");
  });

  it("should emit on click", () => {
    const spy = jest.spyOn(component.clicked, "emit");
    const button = fixture.debugElement.query(By.css("button"));
    button.triggerEventHandler("click", new MouseEvent("click"));
    expect(spy).toHaveBeenCalled();
  });
});
```

## ComponentFixture API

```ts
// Detect changes after modifying inputs
fixture.detectChanges();

// Template queries
fixture.debugElement.query(By.css(".selector"));
fixture.debugElement.queryAll(By.css(".item"));
fixture.debugElement.query(By.directive(ChildComponent));

// Native text
fixture.nativeElement.textContent;
```

## fakeAsync for Temporal Operations

```ts
import { fakeAsync, tick, flush } from "@angular/core/testing";

it("debounce works", fakeAsync(() => {
