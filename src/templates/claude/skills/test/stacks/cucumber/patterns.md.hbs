# Cucumber BDD Test Patterns

## Gherkin (Feature File)

```gherkin
# features/login.feature
Feature: User login
  As a registered user
  I want to log in to the platform
  So that I can access my account

  Scenario: Login with valid credentials
    Given I am on the login page
    When I fill in the email with "admin@test.com"
    And I fill in the password with "password123"
    And I click the "Sign in" button
    Then I should be redirected to "/dashboard"
    And I should see the heading "Dashboard"

  Scenario: Login with invalid credentials
    Given I am on the login page
    When I fill in the email with "wrong@test.com"
    And I fill in the password with "wrong"
    And I click the "Sign in" button
    Then I should see the error message "Invalid credentials"

  Scenario Outline: Field validation
    Given I am on the login page
    When I fill in the email with "<email>"
    And I fill in the password with "<password>"
    And I click the "Sign in" button
    Then I should see the error message "<message>"

    Examples:
      | email           | password | message               |
      |                 | abc      | Email is required      |
      | test@test.com   |          | Password is required   |
```

## Step Definitions

```ts
import { Given, When, Then } from "@cucumber/cucumber";
import { expect } from "@playwright/test";

Given("I am on the login page", async function () {
  await this.page.goto("/login");
});

When("I fill in the email with {string}", async function (email: string) {
  await this.page.getByLabel("Email").fill(email);
});

When("I fill in the password with {string}", async function (pwd: string) {
  await this.page.getByLabel("Password").fill(pwd);
});

When("I click the {string} button", async function (text: string) {
  await this.page.getByRole("button", { name: text }).click();
});

Then("I should be redirected to {string}", async function (url: string) {
  await expect(this.page).toHaveURL(new RegExp(url));
});

Then("I should see the error message {string}", async function (msg: string) {
  await expect(this.page.getByRole("alert")).toContainText(msg);
});
```

