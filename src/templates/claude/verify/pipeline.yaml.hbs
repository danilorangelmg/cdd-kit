# Post-Development Verification Pipeline
# Source of truth for verification stages per module role.
# Executed by: .claude/verify/run.sh
# Integrated via: make verify-{module} | .claude/hooks/post-dev-verify.sh
# Generated by cdd (Copilot-Driven Development)

roles:
  frontend:
    modules:
{{#modulesOfRole "frontend"}}
      - {{directory}}
{{/modulesOfRole}}
    stages:
      - name: lint
        run: npm run lint
        fix: npm run lint -- --fix
      - name: typecheck
        run: npx tsc --noEmit
      - name: test
        run: npm run test
      - name: build
        run: npm run build

