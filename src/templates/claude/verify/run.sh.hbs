#!/usr/bin/env bash
# Post-Development Verification Runner
# Usage: run.sh <module> [--no-fix] [--stage=<name>]
# Default: auto-fix enabled
# Generated by cdd (Copilot-Driven Development)

set -euo pipefail

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# --- Root directory ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

# --- Args ---
MODULE=""
AUTO_FIX=true
ONLY_STAGE=""

for arg in "$@"; do
  case "$arg" in
    --no-fix) AUTO_FIX=false ;;
    --stage=*) ONLY_STAGE="${arg#--stage=}" ;;
    -*) echo -e "${RED}Unknown flag: $arg${NC}"; exit 1 ;;
    *) MODULE="$arg" ;;
  esac
done

if [[ -z "$MODULE" ]]; then
  echo -e "${RED}Usage: run.sh <module> [--no-fix] [--stage=<name>]${NC}"
{{#if (eq project.language "pt-BR")}}
  echo "Modulos: {{#each modules}}{{directory}}{{#unless @last}}, {{/unless}}{{/each}}"
{{else}}
  echo "Modules: {{#each modules}}{{directory}}{{#unless @last}}, {{/unless}}{{/each}}"
{{/if}}
  exit 1
fi

MODULE_DIR="$ROOT_DIR/$MODULE"
if [[ ! -d "$MODULE_DIR" ]]; then
{{#if (eq project.language "pt-BR")}}
  echo -e "${RED}Diretorio nao encontrado: $MODULE_DIR${NC}"
{{else}}
  echo -e "${RED}Directory not found: $MODULE_DIR${NC}"
{{/if}}
  exit 1
fi

# --- Lookup: module → role ---
get_role() {
  case "$1" in
{{#each modules}}
    {{directory}}) echo "{{role}}" ;;
{{/each}}
    *) echo "unknown" ;;
  esac
}

# --- Stage definitions per role ---
# Format: "name|run_cmd|fix_cmd"
get_stages() {
  local role="$1"
  case "$role" in
    frontend)
      echo "lint|npm run lint|npm run lint -- --fix"
      echo "typecheck|npx tsc --noEmit|"
      echo "test|npm run test|"
      echo "build|npm run build|"
      ;;
    backend)
      echo "lint|npm run lint|npm run lint -- --fix"
      echo "typecheck|npx tsc --noEmit|"
      echo "test|npm run test|"
      echo "build|npm run build|"
      ;;
    database)
      echo "lint|npm run lint|npm run lint -- --fix"
      echo "test|npm run test|"
      ;;
    agent-ai)
      echo "lint|npm run lint|npm run lint -- --fix"
      echo "typecheck|npx tsc --noEmit|"
      echo "test|npm run test|"
      ;;
    mobile)
      echo "lint|npm run lint|npm run lint -- --fix"
      echo "typecheck|npx tsc --noEmit|"
      echo "test|npm test|"
      ;;
    e2e)
      echo "lint|npx tsc --noEmit|"
      echo "test-dry|make test-dry|"
      ;;
    generic)
      echo "lint|npm run lint|npm run lint -- --fix"
      echo "test|npm run test|"
      ;;
  esac
}

# --- Execution ---
ROLE=$(get_role "$MODULE")
if [[ "$ROLE" == "unknown" ]]; then
{{#if (eq project.language "pt-BR")}}
  echo -e "${RED}Modulo desconhecido: $MODULE${NC}"
{{else}}
  echo -e "${RED}Unknown module: $MODULE${NC}"
{{/if}}
  exit 1
fi

echo ""
echo -e "${BOLD}${CYAN}=========================================${NC}"
echo -e "${BOLD}${CYAN}  VERIFY: $MODULE ($ROLE)${NC}"
echo -e "${BOLD}${CYAN}=========================================${NC}"
echo ""

# Counters
TOTAL=0
PASSED=0
FIXED=0
FAILED=0
FAILED_STAGES=()

# Process stages
while IFS='|' read -r stage_name run_cmd fix_cmd; do
  # Filter by --stage
  if [[ -n "$ONLY_STAGE" && "$stage_name" != "$ONLY_STAGE" ]]; then
    continue
  fi

  ((TOTAL++)) || true

  echo -e "  ${BLUE}[$TOTAL] $stage_name${NC} ..."

  # Execute
  stage_output=""
  stage_exit=0
  stage_output=$(cd "$MODULE_DIR" && eval "$run_cmd" 2>&1) || stage_exit=$?

  if [[ $stage_exit -eq 0 ]]; then
    ((PASSED++)) || true
    echo -e "  ${GREEN}[PASS]${NC} $stage_name"
  else
    # Try auto-fix
    if [[ "$AUTO_FIX" == true && -n "$fix_cmd" ]]; then
{{#if (eq project.language "pt-BR")}}
      echo -e "  ${YELLOW}[FIX]${NC}  $stage_name — aplicando auto-fix..."
{{else}}
      echo -e "  ${YELLOW}[FIX]${NC}  $stage_name — applying auto-fix..."
{{/if}}
      fix_output=""
      fix_exit=0
      fix_output=$(cd "$MODULE_DIR" && eval "$fix_cmd" 2>&1) || fix_exit=$?

      # Re-check
      recheck_output=""
      recheck_exit=0
      recheck_output=$(cd "$MODULE_DIR" && eval "$run_cmd" 2>&1) || recheck_exit=$?

      if [[ $recheck_exit -eq 0 ]]; then
        ((FIXED++)) || true
{{#if (eq project.language "pt-BR")}}
        echo -e "  ${GREEN}[FIXED]${NC} $stage_name — corrigido automaticamente"
{{else}}
        echo -e "  ${GREEN}[FIXED]${NC} $stage_name — fixed automatically"
{{/if}}
      else
        ((FAILED++)) || true
        FAILED_STAGES+=("$stage_name")
{{#if (eq project.language "pt-BR")}}
        echo -e "  ${RED}[FAIL]${NC} $stage_name — auto-fix nao resolveu"
{{else}}
        echo -e "  ${RED}[FAIL]${NC} $stage_name — auto-fix did not resolve"
{{/if}}
        echo ""
        echo "$recheck_output" | tail -20
        echo ""
      fi
    else
      ((FAILED++)) || true
      FAILED_STAGES+=("$stage_name")
      echo -e "  ${RED}[FAIL]${NC} $stage_name"
      echo ""
      echo "$stage_output" | tail -20
      echo ""
    fi
  fi
done < <(get_stages "$ROLE")

# --- Report ---
echo ""
{{#if (eq project.language "pt-BR")}}
echo -e "${BOLD}${CYAN}--- Relatorio: $MODULE ---${NC}"
{{else}}
echo -e "${BOLD}${CYAN}--- Report: $MODULE ---${NC}"
{{/if}}
echo -e "  Total:    $TOTAL"
echo -e "  ${GREEN}Passed:   $PASSED${NC}"
if [[ $FIXED -gt 0 ]]; then
  echo -e "  ${YELLOW}Fixed:    $FIXED${NC}"
fi
if [[ $FAILED -gt 0 ]]; then
  echo -e "  ${RED}Failed:   $FAILED${NC} (${FAILED_STAGES[*]})"
fi
echo -e "${BOLD}${CYAN}-----------------------------${NC}"
echo ""

if [[ $FAILED -gt 0 ]]; then
  exit 1
fi
exit 0
